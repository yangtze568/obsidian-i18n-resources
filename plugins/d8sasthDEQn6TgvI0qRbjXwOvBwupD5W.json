                {
                    "type": "ObjectProperty",
                    "name": "description",
                    "source": "\\u091A\\u0941\\u0928\\u0947\\u0902 \\u0915\\u093F \\u0938\\u092A\\u094D\\u0924\\u093E\\u0939 \\u0915\\u0947 \\u0915\\u094C\\u0928 \\u0938\\u0947 \\u0926\\u093F\\u0928 \\u092A\\u094D\\u0930\\u0926\\u0930\\u094D\\u0936\\u093F\\u0924 \\u0915\\u0930\\u0928\\u0947 \\u0939\\u0948\\u0902: \\u0938\\u092E \\u0926\\u093F\\u0928 (\\u091C\\u0948\\u0938\\u0947, \\u092E\\u0902\\u0917\\u0932\\u0935\\u093E\\u0930, \\u0917\\u0941\\u0930\\u0941\\u0935\\u093E\\u0930, \\u0936\\u0928\\u093F\\u0935\\u093E\\u0930), \\u0935\\u093F\\u0937\\u092E \\u0926\\u093F\\u0928 (\\u091C\\u0948\\u0938\\u0947, \\u0938\\u094B\\u092E\\u0935\\u093E\\u0930, \\u092C\\u0941\\u0927\\u0935\\u093E\\u0930, \\u0936\\u0941\\u0915\\u094D\\u0930\\u0935\\u093E\\u0930, \\u0930\\u0935\\u093F\\u0935\\u093E\\u0930), \\u0915\\u094B\\u0908 \\u0928\\u0939\\u0940\\u0902 (\\u0915\\u094B\\u0908 \\u092D\\u0940 \\u0926\\u093F\\u0928 \\u092A\\u094D\\u0930\\u0926\\u0930\\u094D\\u0936\\u093F\\u0924 \\u0928 \\u0915\\u0930\\u0947\\u0902), \\u092F\\u093E \\u0938\\u092D\\u0940 (\\u0938\\u092D\\u0940 \\u0938\\u093E\\u0924 \\u0926\\u093F\\u0928 \\u092A\\u094D\\u0930\\u0926\\u0930\\u094D\\u0936\\u093F\\u0924 \\u0915\\u0930\\u0947\\u0902) \n\\u0938\\u092A\\u094D\\u0924\\u093E\\u0939 \\u0915\\u0947 \\u0926\\u093F\\u0928)\\u0964",
                    "target": "\\u9009\\u62E9\\u8981\\u663E\\u793A\\u7684\\u661F\\u671F\\u51E0\\uFF1A\\u5076\\u6570\\u65E5\\uFF08\\u4F8B\\u5982\\u5468\\u4E8C\\u3001\\u5468\\u56DB\\u3001\\u5468\\u516D\\uFF09\\u3001\\u5947\\u6570\\u65E5\\uFF08\\u4F8B\\u5982\\u5468\\u4E00\\u3001\\u5468\\u4E09\\u3001\\u5468\\u4E94\\u3001\\u5468\\u65E5\\uFF09\\u3001\\u201C\\u65E0\\u201D\\uFF08\\u4E0D\\u663E\\u793A\\u4EFB\\u4F55\\u65E5\\u671F\\uFF09\\u6216\\u201C\\u5168\\u90E8\\u201D\\uFF08\\u663E\\u793A\\u4E00\\u5468\\u4E03\\u5929\\uFF09\\u3002 \\n\\u661F\\u671F\\u51E0\\uFF09\\u3002"
